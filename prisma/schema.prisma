generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  CLIENT
  ARTIST
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  // Client specific
  clientEvents  Event[]   @relation("ClientEvents")

  // Artist specific
  artistProfile Artist?

  // Admin specific
  adminActions  AdminAction[]
}

model Artist {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile
  bio             String?  @db.Text
  genres          String[]
  performanceType String[]
  pricing         Json?    // { hourly: number, perEvent: number }
  experience      String?  @db.Text
  location        String?

  // Portfolio
  profileImage    String?
  portfolioImages String[]
  videos          Json[]   // { title: string, url: string, thumbnail: string }

  // Status
  isApproved      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)

  // Availability
  availability    Json?    // Weekly schedule

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  offers          Offer[]
  bookings        Booking[]
}

enum EventStatus {
  PENDING
  MATCHING
  OFFERS_RECEIVED
  OFFER_ACCEPTED
  BOOKED
  COMPLETED
  CANCELLED
}

model Event {
  id            String      @id @default(cuid())
  clientId      String
  client        User        @relation("ClientEvents", fields: [clientId], references: [id], onDelete: Cascade)

  // Event Details
  title         String
  eventType     String      // wedding, corporate, party, etc.
  description   String?     @db.Text

  // Requirements
  budget        Json        // { min: number, max: number }
  date          DateTime
  time          String?
  duration      Int?        // in hours

  // Location
  location      String
  venueType     String?

  // Vibe/Style
  vibe          String[]    // romantic, EDM, Bollywood, etc.

  // Additional
  guestCount    Int?
  notes         String?     @db.Text

  // Status
  status        EventStatus @default(PENDING)

  // Matching
  matchedArtists String[]   // Array of artist IDs

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  offers        Offer[]
  booking       Booking?
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model Offer {
  id            String      @id @default(cuid())
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  artistId      String
  artist        Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)

  // Offer Details
  price         Float
  message       String?     @db.Text
  media         Json[]      // Optional media attachments

  // Status
  status        OfferStatus @default(PENDING)

  // Timestamps
  createdAt     DateTime    @default(now())
  expiresAt     DateTime?   // Offer expiration
  respondedAt   DateTime?   // When client responds

  @@unique([eventId, artistId])
}

enum BookingStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

model Booking {
  id              String        @id @default(cuid())
  eventId         String        @unique
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  artistId        String
  artist          Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)

  // Pricing
  finalPrice      Float
  platformFee     Float         @default(0) // 10% platform fee
  totalAmount     Float

  // Payment
  paymentStatus   BookingStatus @default(PENDING_PAYMENT)
  paymentIntentId String?       // Stripe payment intent ID
  paidAt          DateTime?

  // Status
  status          BookingStatus @default(PENDING_PAYMENT)

  // Dispute
  disputeReason   String?
  disputeStatus   String?       // OPEN, RESOLVED, etc.

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?

  // Relations
  transactions    Transaction[]
}

enum TransactionType {
  PAYMENT
  PAYOUT
  REFUND
  FEE
}

model Transaction {
  id            String          @id @default(cuid())
  bookingId     String
  booking       Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type          TransactionType
  amount        Float
  status        String          // completed, pending, failed

  // Stripe
  stripeId      String?

  // Metadata
  description   String?

  createdAt     DateTime        @default(now())
}

enum AdminActionType {
  APPROVE_ARTIST
  REJECT_ARTIST
  BAN_USER
  UNBAN_USER
  ASSIGN_ARTIST
  RESOLVE_DISPUTE
  REFUND_PAYMENT
}

model AdminAction {
  id            String          @id @default(cuid())
  adminId       String
  admin         User            @relation(fields: [adminId], references: [id], onDelete: Cascade)

  actionType    AdminActionType
  targetUserId  String?         // User affected by the action
  targetId      String?         // Generic target ID (event, booking, etc.)

  reason        String?         @db.Text
  metadata      Json?           // Additional context

  createdAt     DateTime        @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
