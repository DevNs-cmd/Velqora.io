# Video CDN Configuration for Vercel
# Copy this file to .env.local and fill in the CDN URLs

# Option 1: Cloudinary URLs (Recommended)
# Upload videos to Cloudinary and paste the direct URLs here
# Format: https://res.cloudinary.com/YOUR_CLOUD_NAME/video/upload/videos/FILENAME

NEXT_PUBLIC_VIDEO_CONCERT=/concert.mp4
NEXT_PUBLIC_VIDEO_BALLROOM=/ballroom.mp4
NEXT_PUBLIC_VIDEO_DJ=/dj.mov
NEXT_PUBLIC_VIDEO_HERO_1=/hero-1.mp4
NEXT_PUBLIC_VIDEO_HERO_2=/hero-2.mp4

# To use Cloudinary instead of local files, uncomment and update these:
# NEXT_PUBLIC_VIDEO_CONCERT=https://res.cloudinary.com/YOUR_CLOUD/video/upload/videos/concert.mp4
# NEXT_PUBLIC_VIDEO_BALLROOM=https://res.cloudinary.com/YOUR_CLOUD/video/upload/videos/ballroom.mp4
# NEXT_PUBLIC_VIDEO_DJ=https://res.cloudinary.com/YOUR_CLOUD/video/upload/videos/dj.mov
# NEXT_PUBLIC_VIDEO_HERO_1=https://res.cloudinary.com/YOUR_CLOUD/video/upload/videos/hero-1.mp4
# NEXT_PUBLIC_VIDEO_HERO_2=https://res.cloudinary.com/YOUR_CLOUD/video/upload/videos/hero-2.mp4
